# ─────────────────────────────────────────────────────────
# Outred Environment Configuration
# Copy this to .env and adjust values for your environment
# ─────────────────────────────────────────────────────────

# Server port (Railway injects this automatically)
PORT=8000

# Max file upload size in MB (default: 1024 = 1 GB)
MAX_UPLOAD_MB=1024

# CORS allowed origins (comma-separated, default: *)
# Restrict in production, e.g.: https://outred.yourplatform.com
CORS_ORIGINS=*

# Uvicorn workers (keep at 1 for memory-constrained environments)
# Each worker loads its own copy of PyOD/sklearn/numpy (~300 MB)
# WEB_CONCURRENCY=1

# Python logging level (default: INFO)
# Valid: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
